# Exclude everything
/*

# Except for default project files
!/.github
!/libs
!/frontends
!/cmake
!/scripts
!/tests
!/thirdparty
!/tools
!/GNUMakefile
!/LICENSE
!/README.md
!.editorconfig
!.gitignore
!.gitattributes
!.gersemirc
!deps.json
!CMakeLists.txt
!CMakePresets.json

# Exclude old macOS Finder metadata
.DS_Store

# Exclude generated sources that still reside in-tree
libs/ruby/video/metal/shaders.metallib
libs/ruby/video/metal/shaders.ir
libs/ares/ares/resource/resource.cpp
libs/ares/ares/resource/resource.hpp
libs/hiro/resource/resource.cpp
libs/hiro/resource/resource.hpp
frontends/desktop-ui/resource/resource.cpp
frontends/desktop-ui/resource/resource.hpp
libs/mia/resource/resource.cpp
libs/mia/resource/resource.hpp

# Exclude fetched third-party processor test binaries
tests/arm7tdmi/tests
tests/m68000/tests

# Exclude unused legacy zlib header that is renamed by CMake
thirdparty/libchdr/deps/zlib-*/zconf.h
thirdparty/libchdr/deps/zlib-*/zconf.h.included
